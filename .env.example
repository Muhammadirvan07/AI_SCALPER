# Safe development defaults. Never store broker login or password in this file.
AI_SCALPER_MODE=SHADOW
# Fail-closed placeholder. Never persist the exact account/server/mode/journal token here.
AI_SCALPER_EXECUTION_ARM=UNARMED
AI_SCALPER_LIVE_ALLOWED=false
AI_SCALPER_SAFE_TO_DEMO_AUTO_ORDER=false
AI_SCALPER_MAX_LOT=0.01
AI_SCALPER_JOURNAL_PATH=runtime_state/execution.sqlite
AI_SCALPER_ACCOUNT_ALIAS=UNCONFIGURED
AI_SCALPER_EXPECTED_SERVER=UNCONFIGURED
AI_SCALPER_PROMOTION_PERMIT_PATH=UNCONFIGURED
AI_SCALPER_OFFHOST_HEARTBEAT_URL=UNCONFIGURED
